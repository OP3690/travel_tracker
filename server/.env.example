# Copy to .env and fill in values. Never commit the real .env.

# SMTP — defaults assume Google Workspace for support@stampyourmap.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=support@stampyourmap.com
SMTP_PASS=                          # app password (required to actually send)

# Branding
EMAIL_FROM_NAME=StampYourMap
APP_URL=https://stampyourmap.com

# Dev mode: redirect ALL outbound mail to this address for review.
# Leave empty in production to send to real recipients.
EMAIL_REDIRECT_TO=global5665@gmail.com
